{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triagecore.local/schemas/runtime_efficiency_record.schema.json",
  "title": "TriageCore Runtime Efficiency Record",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "task_digest",
    "task_class",
    "baseline_route",
    "selected_route",
    "runtime_backend",
    "token_metrics",
    "latency_metrics",
    "benefits",
    "energy",
    "measurement_tier",
    "quality_gate"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "runtime_efficiency_record.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "task_digest": {"type": "string", "minLength": 1},
    "task_class": {"type": "string", "minLength": 1},
    "baseline_route": {"type": "string", "minLength": 1},
    "selected_route": {"type": "string", "minLength": 1},
    "runtime_backend": {
      "type": "object",
      "required": ["name", "endpoint_kind"],
      "additionalProperties": true,
      "properties": {
        "name": {"enum": ["ollama", "llama_cpp", "generic_openai_compatible"]},
        "endpoint_kind": {"enum": ["ollama_api", "openai_compatible"]}
      }
    },
    "token_metrics": {
      "type": "object",
      "required": ["baseline", "selected"],
      "additionalProperties": false,
      "properties": {
        "baseline": {"$ref": "#/$defs/token_block"},
        "selected": {"$ref": "#/$defs/token_block"}
      }
    },
    "latency_metrics": {
      "type": "object",
      "required": ["baseline", "selected"],
      "additionalProperties": false,
      "properties": {
        "baseline": {"$ref": "#/$defs/latency_block"},
        "selected": {"$ref": "#/$defs/latency_block"}
      }
    },
    "benefits": {
      "type": "object",
      "required": [
        "claims_valid",
        "tokens_saved",
        "token_reduction_ratio",
        "latency_saved_ms",
        "measured_energy_saved_wh"
      ],
      "additionalProperties": false,
      "properties": {
        "claims_valid": {"type": "boolean"},
        "tokens_saved": {"type": ["integer", "null"]},
        "token_reduction_ratio": {"type": ["number", "null"]},
        "latency_saved_ms": {"type": ["number", "null"]},
        "measured_energy_saved_wh": {"type": ["number", "null"]}
      }
    },
    "energy": {
      "type": "object",
      "required": [
        "baseline_energy_wh",
        "estimated_energy_wh",
        "measured_energy_wh",
        "measurement_method",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "baseline_energy_wh": {"type": ["number", "null"], "minimum": 0},
        "estimated_energy_wh": {"type": ["number", "null"], "minimum": 0},
        "measured_energy_wh": {"type": ["number", "null"], "minimum": 0},
        "measurement_method": {"type": ["string", "null"]},
        "notes": {"type": ["string", "null"]}
      }
    },
    "measurement_tier": {
      "enum": [
        "token_proxy",
        "runtime_proxy",
        "software_energy_estimate",
        "wall_power_measured"
      ]
    },
    "quality_gate": {
      "type": "object",
      "required": ["passed", "method", "notes"],
      "additionalProperties": false,
      "properties": {
        "passed": {"type": "boolean"},
        "method": {"type": "string", "minLength": 1},
        "notes": {"type": ["string", "null"]}
      }
    }
  },
  "$defs": {
    "token_block": {
      "type": "object",
      "required": ["prompt_tokens", "completion_tokens", "total_tokens", "token_budget"],
      "additionalProperties": false,
      "properties": {
        "prompt_tokens": {"type": ["integer", "null"], "minimum": 0},
        "completion_tokens": {"type": ["integer", "null"], "minimum": 0},
        "total_tokens": {"type": ["integer", "null"], "minimum": 0},
        "token_budget": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "latency_block": {
      "type": "object",
      "required": [
        "total_latency_ms",
        "time_to_first_token_ms",
        "decode_tokens_per_second",
        "prompt_tokens_per_second"
      ],
      "additionalProperties": false,
      "properties": {
        "total_latency_ms": {"type": ["number", "null"], "minimum": 0},
        "time_to_first_token_ms": {"type": ["number", "null"], "minimum": 0},
        "decode_tokens_per_second": {"type": ["number", "null"], "minimum": 0},
        "prompt_tokens_per_second": {"type": ["number", "null"], "minimum": 0}
      }
    }
  }
}
